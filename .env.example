# ──────────────────────────────────────────────
# 쇼핑숏츠 자율수익화 시스템 환경변수
# 복사: cp .env.example .env.local
# ──────────────────────────────────────────────

# [필수] Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# [필수] Cron 보안 키 (임의 문자열 생성)
CRON_SECRET=your-secret-cron-key-here

# [선택] Mock 모드 (true = 실제 API 미사용, 개발용)
USE_MOCK_DATA=false

# ──────────────────────────────────────────────
# 쿠팡 파트너스 API (https://partners.coupang.com)
# ──────────────────────────────────────────────
COUPANG_ACCESS_KEY=your-coupang-access-key
COUPANG_SECRET_KEY=your-coupang-secret-key

# ──────────────────────────────────────────────
# YouTube Data API v3 (Google Cloud Console)
# 1. https://console.cloud.google.com 에서 프로젝트 생성
# 2. YouTube Data API v3 활성화
# 3. OAuth 2.0 클라이언트 ID 생성
# 4. Refresh Token은 /setup 페이지에서 발급
# ──────────────────────────────────────────────
YOUTUBE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=your-google-client-secret
YOUTUBE_REFRESH_TOKEN=your-youtube-refresh-token
YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxxxxxxx

# ──────────────────────────────────────────────
# 앱 URL (Vercel 배포 후 자동으로 채워짐)
# ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
