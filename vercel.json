{
  "crons": [
    {
      "path": "/api/cron/daily",
      "schedule": "0 17 * * *"
    },
    {
      "path": "/api/cron/revenue-sync",
      "schedule": "0 21 * * *"
    },
    {
      "path": "/api/agent/autofix",
      "schedule": "*/10 * * * *"
    }
  ],
  "functions": {
    "src/app/api/**": {
      "maxDuration": 60
    },
    "src/app/api/cron/**": {
      "maxDuration": 300
    },
    "src/app/api/webhook/**": {
      "maxDuration": 120
    }
  }
}
